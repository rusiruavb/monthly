# Recommended: path to the JSON key file from Google Cloud (keep out of git)
GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/google-service-account.json

# Alternative: entire JSON on ONE line, wrapped in single quotes (fragile — prefer PATH above)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# Drive folder ID where receipts/attachments are stored.
# Must be in a Shared drive (Workspace) with the service account as Content manager,
# OR use GOOGLE_DRIVE_IMPERSONATE_USER with a folder in that user's My Drive.
GOOGLE_DRIVE_FOLDER_ID=your_folder_id

# Optional (Google Workspace): upload as this user via domain-wide delegation
# GOOGLE_DRIVE_IMPERSONATE_USER=you@yourcompany.com

# API server port
PORT=3001

# Optional: share link shown in Share action (defaults to spreadsheet URL from API)
VITE_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id/edit
