# SQLite database path
DATABASE_PATH=./data/cfima.db

# Local data directory (database + attachments)
DATA_DIR=./data

# API server port (Render sets PORT automatically)
PORT=3001

# Bind address (0.0.0.0 for Render/Docker)
HOST=0.0.0.0

# Public app URL — used for CORS in development (optional when API serves the UI)
CLIENT_URL=http://localhost:5173

# Production on Render (set in dashboard or render.yaml):
# NODE_ENV=production
# DATA_DIR=/var/data
# DATABASE_PATH=/var/data/cfima.db
# CLIENT_URL=https://your-app.onrender.com
